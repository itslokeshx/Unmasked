# 🎭 UNMASKED Environment Configuration Template

# Groq API Key (Required for Llama 3.1 8B Instant inference)
# Obtain your API key from the Groq Developer Console: https://console.groq.com/
GROQ_API=your_groq_api_key_here

# Hugging Face Access Token (Optional)
# Required if you hit Hugging Face rate limits or want to load gated models.
# Obtain a read token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
